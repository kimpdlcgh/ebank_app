rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - secure access with username lookup capability
    match /users/{userId} {
      // Allow reading only username and email fields for authentication lookups
      // This enables the login system to find users by username
      allow read: if request.query.limit == 1 && 
                     resource.data.keys().hasOnly(['username', 'email', 'role', 'uid']) ||
                     // Allow authenticated users to read their own full data
                     (request.auth != null && request.auth.uid == userId) ||
                     // Allow admins to read all user data
                     (request.auth != null && 
                      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'));
      
      // Allow authenticated users to update their own data (password changes, profile updates)
      allow update: if request.auth != null && request.auth.uid == userId;

      // Allow authenticated users to create their own profile (bootstrap)
      allow create: if request.auth != null && request.auth.uid == userId &&
            (request.resource.data.role in ['client', 'admin', 'super_admin']);
      
      // Allow admins to create and delete user accounts
      allow create, delete: if request.auth != null && 
                exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                 get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }

    // Public lookup collection for client login
    match /users_public/{userId} {
      allow read: if true;
      allow write: if request.auth != null && 
                    exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }
    
    // Bank accounts - strict access control
    match /accounts/{accountId} {
      // Only account owners and admins can access account data
      allow read, write: if request.auth != null && 
                           (resource.data.userId == request.auth.uid ||
                            (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'));
      
      // Allow admins to create accounts for users
      allow create: if request.auth != null && 
                       exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                       (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }
    
    // Transactions - account owner and admin access only
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null && 
                           (resource.data.userId == request.auth.uid ||
                            (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'));
    }
    
    // System configuration - public read, admin write
    match /systemConfig/{document} {
      // Allow all users to read system config (for branding, logos, etc.)
      allow read: if true;
      
      // Only admins can modify system configuration
      allow write: if request.auth != null && 
                      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }

    // System configuration (snake_case collection) - public read, admin write
    match /system_config/{document} {
      allow read: if true;
      allow write: if request.auth != null && 
                      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }
    
    // Countries data - public read for forms, admin write
    match /countries/{country} {
      allow read: if true;
      allow write: if request.auth != null && 
                      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }
    
    // Support tickets and communications
    match /support/{ticketId} {
      // Users can read/write their own tickets, admins can access all
      allow read, write: if request.auth != null && 
                           (resource.data.userId == request.auth.uid ||
                            (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'));
      
      // Allow creating support tickets
      allow create: if request.auth != null;
    }

    // Support requests (snake_case)
    match /support_requests/{requestId} {
      allow read, write: if request.auth != null && 
                           (resource.data.userId == request.auth.uid ||
                            (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin')));
      allow create: if request.auth != null || request.auth == null;
    }

    // Password reset requests
    match /password_reset_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }

    // Admin notifications
    match /admin_notifications/{notificationId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }
    
    // Audit logs - admin only
    match /audit_logs/{logId} {
      allow read, write: if request.auth != null && 
                           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }
    
    // Default deny for any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}